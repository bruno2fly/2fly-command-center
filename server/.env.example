# Database — switch to postgres for production:
# DATABASE_URL="postgresql://user:pass@localhost:5432/2fly_command_center"
DATABASE_URL="file:./dev.db"

PORT=4000

# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+13637770337
TWILIO_WEBHOOK_AUTH_TOKEN=optional_custom_secret
# Dev only: skip Twilio webhook signature validation when behind Cloudflare Tunnel. Set false or remove in production!
# SKIP_TWILIO_SIGNATURE_VALIDATION=true

# Notification target
BRUNO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# LLM fallback (optional, heuristics work without this)
OPENAI_API_KEY=sk-...

# Classifier tuning
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6
CLASSIFIER_USE_LLM_FALLBACK=true
DEFAULT_DUE_WINDOW_DAYS=3
NOTIFICATION_ENABLED=true

# Optional alias for Twilio WhatsApp number
TWILIO_WHATSAPP_FROM=whatsapp:+13637770337

# Admin password for WhatsApp Chat dashboard (/admin/whatsapp). If unset, no auth required.
# ADMIN_PASSWORD=your_admin_password

# Email / Invoice sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@2flydigital.com
SMTP_PASS=your-app-password
SMTP_FROM="2FLY Digital Marketing" <hello@2flydigital.com>
